# ============================================================
# Maira — variables de entorno (ejemplo)
# Copia a .env y rellena. NUNCA commitees el .env real.
# Todos los servicios son free tier (restricción del TFM: coste 0€).
# ============================================================

# --- Backend (FastAPI) ---
# Entorno: development | production
ENVIRONMENT=development
# Clave para firmar tokens internos (genera una: python -c "import secrets; print(secrets.token_urlsafe(48))")
SECRET_KEY=cambia-esta-clave-por-una-aleatoria-larga
# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:3000

# --- Base de datos ---
# Local (docker compose): postgresql+asyncpg://maira:maira@localhost:5432/maira
# Producción: cadena de conexión de Supabase (Settings > Database)
DATABASE_URL=postgresql+asyncpg://maira:maira@localhost:5432/maira

# --- Supabase (Auth + Storage) ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=eyJ...anon
# Solo backend, NUNCA exponer al frontend
SUPABASE_SERVICE_KEY=eyJ...service

# --- LLM (fichas + triaje) ---
# Proveedor activo: groq | gemini
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_...
# Fallback gratuito
GEMINI_API_KEY=AIza...

# --- Computer Vision (HuggingFace) ---
HF_API_TOKEN=hf_...

# --- Vector DB (RAG triaje) ---
QDRANT_URL=https://xyz.cloud.qdrant.io
QDRANT_API_KEY=...

# --- Monitorización (free) ---
# URL de ping de Healthchecks.io (vacío = desactivado)
HEALTHCHECKS_PING_URL=

# --- Frontend (Next.js) — prefijo NEXT_PUBLIC_ = visible en el navegador ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon

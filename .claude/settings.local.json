{
  "permissions": {
    "allow": [
      "Bash(curl -s -f https://www.gnu.org/licenses/agpl-3.0.txt -o LICENSE)",
      "PowerShell(Invoke-WebRequest -Uri \"https://www.gnu.org/licenses/agpl-3.0.txt\" -OutFile LICENSE -UseBasicParsing && \\(Get-Content LICENSE | Measure-Object -Line\\).Lines)",
      "PowerShell(Invoke-WebRequest -Uri \"https://raw.githubusercontent.com/spdx/license-list-data/main/text/AGPL-3.0-only.txt\" -OutFile LICENSE -UseBasicParsing && \\(Get-Content LICENSE -TotalCount 3\\) && \\(Get-Content LICENSE | Measure-Object -Line\\).Lines)",
      "PowerShell(Get-Content *)",
      "PowerShell(pip install *)",
      "Bash(grep -E '\\\\.env$|\\\\.\\(pdf|docx|xlsx\\)$')"
    ]
  }
}
